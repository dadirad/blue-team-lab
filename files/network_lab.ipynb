SUSP_DOMAIN = ""  # e.g., "update-microsoft-security[.]com"
if not SUSP_DOMAIN:
    print("Optional: set SUSP_DOMAIN to pivot across DNS/TLS/HTTP and re-run.")
else:
    domain_events = df[
        (df["query"]==SUSP_DOMAIN) |
        (df["sni"]==SUSP_DOMAIN) |
        (df["http_host"]==SUSP_DOMAIN)
    ].copy()

    cols = ["ts","event_type","src_ip","src_host","dst_ip","dst_port","query","sni","http_host","uri","status","bytes_in","notes"]
    display(domain_events[cols].sort_values("ts"))

